import java.util.*;

class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int[] a=new int[n];
        
        System.out.println("Enter the "+n+" numbers");
        
        for(int i=0; i<n; i++)
        {
            int num=sc.nextInt();
            a[i]=num;
        }
        
        System.out.println(Arrays.toString(a));
    }
}
